# Copy to .env and fill in real values. .env is gitignored — never commit real secrets.

DOMAIN=candidate-name.stratus-eval.dev
PG_PASSWORD=changeme-strong-random-password
GRAFANA_ADMIN_PASSWORD=changeme-strong-random-password
VAPI_WEBHOOK_SECRET=whsec_xxx_from_vapi_dashboard
VAPI_API_KEY=                           # Settings -> API Keys in Vapi dashboard, used only by scripts/setup-vapi-agent.sh
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx
BACKUP_S3_BUCKET=                       # optional, leave empty to keep local-only backups
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
